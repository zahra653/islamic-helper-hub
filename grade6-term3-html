function markTest(){

let score = 0;

// Maths
if(q5.value=="10") score++;
if(q6.value=="25") score++;
if(q8.value=="60") score++;

// Comprehension
if(q1.value!="") score++;
if(q2.value!="") score++;
if(q3.value!="") score++;
if(q4.value!="") score++;

// General
for(let i=7;i<=25;i++){
if(document.getElementById("q"+i).value!=""){
score++;
}
}

// Show result
document.getElementById("result").innerText =
"🎉 Score: " + score + "/25";

// SAVE SCORE
let existing = localStorage.getItem("scores");
let newScore = "Grade 6 Term 3: " + score + "/25";

if(existing){
existing = existing + "\n" + newScore;
} else {
existing = newScore;
}

localStorage.setItem("scores", existing);

}

